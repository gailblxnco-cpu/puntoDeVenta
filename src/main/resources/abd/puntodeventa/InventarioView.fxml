<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="abd.puntodeventa.InventarioController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="bg-subtle">
            <padding><Insets bottom="15" left="20" right="20" top="15" /></padding>
           <children>
               <Label styleClass="title-3" text="Gestión de Inventario" />
               <Region HBox.hgrow="ALWAYS" />
               <Button onAction="#volverAlMenu" styleClass="flat, danger" text="Cerrar Módulo" />
           </children>
        </HBox>
    </top>

    <center>
        <HBox spacing="15">
            <padding><Insets bottom="15" left="15" right="15" top="15" /></padding>
           <children>
   
               <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
      <children>
                      <TextField fx:id="txtBuscar" promptText="Buscar producto..." />
                      <TableView fx:id="tablaInventario" onMouseClicked="#seleccionarProducto" VBox.vgrow="ALWAYS">
                          <columns>
                              <TableColumn fx:id="colId" prefWidth="60" text="ID" />
                              <TableColumn fx:id="colNombre" prefWidth="250" text="Nombre" />
                              <TableColumn fx:id="colPrecio" prefWidth="100" text="Precio" />
                              <TableColumn fx:id="colStock" editable="false" prefWidth="80" text="Stock" />
                          </columns>
                      </TableView>
      </children>
               </VBox>
   
               <VBox prefWidth="350" spacing="15" styleClass="card">
      <children>
                      <Label styleClass="title-4" text="Detalles del Producto" />
      
                      <VBox spacing="12">
         <children>
                             <TextField fx:id="txtId" editable="false" promptText="ID (Automático)" />
                             <TextField fx:id="txtNombre" promptText="Nombre del producto" />
                             <TextField fx:id="txtPrecio" promptText="Precio de venta" />
                             <TextField fx:id="txtStock" promptText="Cantidad inicial" />
         </children>
                      </VBox>
      
                      <Region VBox.vgrow="ALWAYS" />
      
                      <VBox spacing="10">
         <children>
                             <Button maxWidth="Infinity" onAction="#handleGuardar" styleClass="success" text="AGREGAR PRODUCTO" />
                             <Button maxWidth="Infinity" onAction="#handleModificar" styleClass="warning" text="MODIFICAR" />
                             <Button maxWidth="Infinity" onAction="#handleLimpiar" styleClass="flat" text="LIMPIAR CAMPOS" />
         </children>
                      </VBox>
      </children>
               </VBox>
           </children>
        </HBox>
    </center>
</BorderPane>
