<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane stylesheets="@estilos.css" style="-fx-background-color: #f5f6fa;" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="abd.puntodeventa.MenuPrincipalController">

    <VBox spacing="45" alignment="CENTER" maxWidth="950">
        <padding><Insets top="60" right="60" bottom="60" left="60"/></padding>

        <VBox alignment="CENTER" spacing="8">
            <Label text="Gen POS" style="-fx-font-size: 52px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <HBox alignment="CENTER" spacing="10">
                <Separator prefWidth="50" style="-fx-opacity: 0.5;"/>
                <Label text="MENÚ PRINCIPAL" style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d; -fx-letter-spacing: 4px; -fx-font-weight: bold;"/>
                <Separator prefWidth="50" style="-fx-opacity: 0.5;"/>
            </HBox>
        </VBox>

        <FlowPane hgap="30" vgap="30" alignment="CENTER" prefWrapLength="550">

            <Button text="PUNTO DE VENTA" onAction="#irAVentas" prefWidth="240" prefHeight="160"
                    style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-font-size: 17px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(44, 62, 80, 0.3), 15, 0, 0, 8);"/>

            <Button text="INVENTARIO" onAction="#irAInventario" prefWidth="240" prefHeight="160"
                    style="-fx-background-color: #bdc3c7; -fx-text-fill: #2c3e50; -fx-font-size: 17px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(189, 195, 199, 0.4), 15, 0, 0, 8);"/>

            <Button fx:id="btnUsuarios" text="USUARIOS (ADMIN)" onAction="#irAUsuarios" prefWidth="240" prefHeight="160"
                    style="-fx-background-color: #502c50; -fx-text-fill: white; -fx-font-size: 17px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(231, 76, 60, 0.3), 15, 0, 0, 8);"/>

            <Button text="REPORTES" onAction="#irAReportes" prefWidth="240" prefHeight="160"
                    style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-size: 17px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(243, 156, 18, 0.3), 15, 0, 0, 8);"/>

        </FlowPane>

        <VBox alignment="CENTER" spacing="20">
            <Separator maxWidth="550" style="-fx-opacity: 0.3;"/>
            <Button text="CERRAR SESIÓN" onAction="#cerrarSesion" styleClass="btn-volver"
                    style="-fx-font-size: 14px;"/>
        </VBox>

    </VBox>
</StackPane>