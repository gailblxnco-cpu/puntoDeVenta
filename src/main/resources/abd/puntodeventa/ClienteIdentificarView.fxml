<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="abd.puntodeventa.ClienteController">
    <VBox maxWidth="450" maxHeight="450" spacing="25" alignment="CENTER" styleClass="card, elevated-3">
        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

        <Label text="Identificar Cliente" styleClass="title-2"/>

        <VBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Número de Teléfono:" style="-fx-font-weight: bold;"/>
            <TextField fx:id="txtTelefonoBusqueda" promptText="Ej. 8331234567"/>
        </VBox>

        <VBox spacing="12">
            <Button text="BUSCAR CLIENTE" onAction="#buscarCliente" maxWidth="Infinity" styleClass="accent"/>

            <Separator/>

            <VBox spacing="8" alignment="CENTER">
                <Label text="¿No tiene cuenta todavía?" styleClass="text-muted"/>
                <Button text="REGISTRAR NUEVO CLIENTE" onAction="#irARegistro" maxWidth="Infinity" styleClass="success, outlined"/>
            </VBox>
        </VBox>

        <Button text="Volver a la Caja" onAction="#cerrarVentana" styleClass="flat"/>
    </VBox>
</StackPane>