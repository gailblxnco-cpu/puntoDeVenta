<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane stylesheets="@estilos.css" style="-fx-background-color: #f5f6fa;" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="abd.puntodeventa.ClienteController">

    <VBox maxWidth="450" maxHeight="500" spacing="25" alignment="CENTER"
          style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">

        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

        <Label text="Identificar Cliente" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

        <VBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Número de Teléfono:" style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;"/>
            <TextField fx:id="txtTelefonoBusqueda" promptText="Ej. 8331234567"
                       style="-fx-padding: 12px; -fx-background-radius: 8; -fx-border-color: #dcdde1; -fx-border-radius: 8;"/>
        </VBox>

        <Button text="BUSCAR CLIENTE" onAction="#buscarCliente" maxWidth="Infinity"
                styleClass="btn-primary-pos" />

        <Separator/>

        <VBox spacing="10" alignment="CENTER">
            <Label text="¿No tiene cuenta todavía?" style="-fx-text-fill: #95a5a6; -fx-font-size: 13px;"/>
            <Button text="REGISTRAR NUEVO CLIENTE" onAction="#irARegistro" maxWidth="Infinity"
                    styleClass="btn-secondary-pos" />
        </VBox>

        <Button text="Volver a la Caja" onAction="#cerrarVentana"
                styleClass="btn-volver"/>
    </VBox>
</StackPane>