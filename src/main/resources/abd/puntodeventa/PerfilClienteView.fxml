<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="abd.puntodeventa.PerfilClienteController">
    <VBox maxWidth="450" maxHeight="550" spacing="25" alignment="CENTER" styleClass="card, elevated-3">
        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

        <Label text="Recompensas" styleClass="title-2"/>

        <VBox alignment="CENTER" spacing="5">
            <Label fx:id="lblNombreCliente" text="Nombre del Cliente" styleClass="title-4"/>
            <Label fx:id="lblTelefonoCliente" text="833-000-0000" styleClass="text-muted"/>
        </VBox>

        <VBox alignment="CENTER" spacing="5" styleClass="card, bg-subtle">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <Label text="PUNTOS DISPONIBLES" style="-fx-font-weight: bold;"/>
            <Label fx:id="lblPuntos" text="0" styleClass="title-1, warning"/>
            <Label text="1 punto = $0.10 de descuento" styleClass="text-muted, caption"/>
        </VBox>

        <VBox spacing="10">
            <Button text="USAR PUNTOS EN ESTA VENTA" onAction="#aplicarPuntos" maxWidth="Infinity" styleClass="warning"/>
            <Button text="Volver a la Caja" onAction="#regresarACaja" maxWidth="Infinity" styleClass="flat"/>
        </VBox>
    </VBox>
</StackPane>