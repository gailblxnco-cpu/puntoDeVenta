<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="25" alignment="CENTER" style="-fx-background-color: #2c3e50; -fx-padding: 30;" xmlns:fx="http://javafx.com/fxml" fx:controller="abd.puntodeventa.PerfilClienteController">
    <Label text="Perfil del Cliente" textFill="WHITE" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <VBox alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20;">
        <Label fx:id="lblNombreCliente" text="Nombre del Cliente" style="-fx-font-size: 18px;"/>
        <Label fx:id="lblTelefonoCliente" text="555-0000" textFill="#7f8c8d"/>

        <Separator prefHeight="20"/>

        <Label text="PUNTOS ACUMULADOS" style="-fx-font-size: 12px;"/>
        <Label fx:id="lblPuntos" text="0" textFill="#f39c12" style="-fx-font-size: 48px; -fx-font-weight: bold;"/>
    </VBox>

    <Button text="USAR PUNTOS EN ESTA VENTA" onAction="#aplicarPuntos" maxWidth="Infinity" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold;"/>
    <Button text="VOLVER A LA CAJA" onAction="#regresarACaja" maxWidth="Infinity" style="-fx-background-color: #bdc3c7;"/>
</VBox>