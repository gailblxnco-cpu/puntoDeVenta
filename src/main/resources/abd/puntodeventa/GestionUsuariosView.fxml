<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane stylesheets="@estilos.css" style="-fx-background-color: #f5f6fa;" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="abd.puntodeventa.UsuarioController">

    <VBox maxWidth="850" maxHeight="600" spacing="25" alignment="CENTER"
          style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">

        <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

        <VBox alignment="CENTER" spacing="5">
            <Label text="Gestión de Personal" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Separator maxWidth="250" style="-fx-opacity: 0.5;"/>
        </VBox>

        <HBox spacing="35" VBox.vgrow="ALWAYS">

            <VBox spacing="15" prefWidth="280">
                <Label text="Datos del Usuario" style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d; -fx-font-size: 16px;"/>

                <VBox spacing="5">
                    <Label text="Nombre de usuario:" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                    <TextField fx:id="txtNuevoUser" promptText="Ej. Aby" style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #bdc3c7; -fx-border-radius: 5;"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Contraseña:" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                    <PasswordField fx:id="txtNuevoPass" promptText="••••••••" style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #bdc3c7; -fx-border-radius: 5;"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Rol en el sistema:" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                    <ComboBox fx:id="cbRol" promptText="Seleccionar Rol" maxWidth="Infinity" style="-fx-padding: 5; -fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-radius: 5;"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <VBox spacing="10">
                    <Button text="CREAR NUEVO" onAction="#crearUsuario" maxWidth="Infinity"
                            style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 5; -fx-cursor: hand;"/>

                    <Button text="MODIFICAR SELECCIONADO" onAction="#modificarUsuario" maxWidth="Infinity"
                            style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 5; -fx-cursor: hand;"/>

                    <Button text="ELIMINAR SELECCIONADO" onAction="#eliminarUsuario" maxWidth="Infinity"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 5; -fx-cursor: hand;"/>

                    <Button text="LIMPIAR CAMPOS" onAction="#limpiarCampos" maxWidth="Infinity"
                            style="-fx-background-color: #bdc3c7; -fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 5; -fx-cursor: hand;"/>
                </VBox>
            </VBox>

            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="Usuarios Registrados" style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d; -fx-font-size: 16px;"/>
                <TableView fx:id="tablaUsuarios" VBox.vgrow="ALWAYS" onMouseClicked="#seleccionarUsuario" style="-fx-border-color: #bdc3c7; -fx-border-radius: 5;">
                    <columns>
                        <TableColumn fx:id="colUser" text="Usuario" prefWidth="250"/>
                        <TableColumn fx:id="colRol" text="Rol Asignado" prefWidth="150"/>
                    </columns>
                </TableView>
            </VBox>
        </HBox>

        <Separator/>
        <Button text="Volver al Menú Principal" onAction="#volverMenu" styleClass="btn-volver" style="-fx-font-size: 14px;"/>

    </VBox>
</StackPane>