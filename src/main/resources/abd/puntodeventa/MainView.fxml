<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane stylesheets="@estilos.css" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="abd.puntodeventa.MainController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label text="Gen POS" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS" />

            <Button text="Cliente / Puntos" onAction="#abrirVentanaCliente"
                    style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>

            <Button text="Inventario" onAction="#abrirInventario"
                    style="-fx-background-color: #bdc3c7; -fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-cursor: hand;"/>

            <Label text="Cajera: Aby" styleClass="user-label"/>
        </HBox>
    </top>

    <center>
        <HBox>
            <VBox prefWidth="380" spacing="15" styleClass="cart-panel">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <Label text="Detalle del Pedido" styleClass="header-label"/>

                <TableView fx:id="tablaPedido" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNombre" text="Café" prefWidth="220"/>
                        <TableColumn fx:id="colPrecio" text="Precio" prefWidth="100"/>
                    </columns>
                </TableView>

                <VBox spacing="5" style="-fx-padding: 10; -fx-border-color: #f39c12; -fx-border-radius: 5; -fx-background-color: #fdfaf0;">
                    <Label fx:id="lblClienteActivo" text="Cliente: Ninguno" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Label fx:id="lblDescuento" text="Descuento: $0.00" style="-fx-text-fill: #e67e22;"/>
                </VBox>

                <VBox spacing="10">
                    <HBox>
                        <Label text="Subtotal:" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblSubtotal" text="0.00" />
                    </HBox>
                    <HBox>
                        <Label text="Total:" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblTotal" text="0.00" styleClass="total-text" />
                    </HBox>
                </VBox>

                <Button text="COBRAR" maxWidth="Infinity" onAction="#handlePago" styleClass="btn-pay" style="-fx-cursor: hand;"/>
            </VBox>

            <VBox HBox.hgrow="ALWAYS" spacing="20" styleClass="inventory-panel">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <TextField fx:id="txtBuscar" promptText="Buscar bebida..." maxWidth="300" styleClass="search-field"/>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-dark">
                    <FlowPane fx:id="flowProductos" hgap="15" vgap="15" />
                </ScrollPane>
            </VBox>
        </HBox>
    </center>
</BorderPane>