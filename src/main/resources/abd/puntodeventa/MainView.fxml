<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="abd.puntodeventa.MainController">

    <left>
        <VBox spacing="15" styleClass="bg-inset" prefWidth="180">
            <padding><Insets top="20" right="15" bottom="20" left="15"/></padding>

            <Label text="☕ Gen POS" styleClass="title-3" wrapText="true"/>
            <Separator style="-fx-padding: 10 0;"/>

            <Button text="🏠 Menú Principal" onAction="#volverAlMenu" maxWidth="Infinity" styleClass="flat"/>
            <Button text="👤 Buscar Clientes" onAction="#abrirVentanaCliente" maxWidth="Infinity" styleClass="warning, flat"/>

            <Region VBox.vgrow="ALWAYS" />
            <Label fx:id="lblCajero" styleClass="text-muted, caption"/>
        </VBox>
    </left>

    <center>
        <HBox spacing="15">
            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

            <VBox prefWidth="350" spacing="12" styleClass="card">
                <Label text="Detalle de Venta" styleClass="title-4"/>

                <TableView fx:id="tablaPedido" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNombre" text="Producto" />
                        <TableColumn fx:id="colPrecio" text="Precio" />
                    </columns>
                </TableView>

                <Button text="Quitar Seleccionado" onAction="#quitarArticulo" maxWidth="Infinity" styleClass="danger, outlined"/>

                <VBox spacing="5" styleClass="bg-subtle" style="-fx-padding: 10; -fx-background-radius: 8;">
                    <Label fx:id="lblClienteActivo" text="👤 Público General" styleClass="text-bold"/>
                    <Separator/>

                    <HBox alignment="CENTER_LEFT">
                        <Label text="Subtotal:" styleClass="text-muted"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblSubtotal" text="0.00" styleClass="text-muted"/>
                    </HBox>

                    <Label fx:id="lblDescuento" text="🎁 Descuento: $0.00" styleClass="warning, caption"/>

                    <HBox alignment="CENTER_LEFT">
                        <Label text="Total a Pagar:" styleClass="title-3"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblTotal" text="0.00" styleClass="title-3"/>
                    </HBox>
                </VBox>
                <Button text="💵 PROCESAR PAGO" onAction="#handlePago" maxWidth="Infinity" prefHeight="40" styleClass="success, elevated-2"/>
            </VBox>

            <VBox HBox.hgrow="ALWAYS" spacing="15" styleClass="card">
                <TextField fx:id="txtBuscar" promptText="🔍 Buscar producto..."/>
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                    <FlowPane fx:id="flowProductos" hgap="15" vgap="15" />
                </ScrollPane>
            </VBox>
        </HBox>
    </center>
</BorderPane>